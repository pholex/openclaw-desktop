{
  "name": "openclaw-desktop",
  "version": "1.0.0",
  "description": "OpenClaw Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:all": "electron-builder --mac --win --publish never"
  },
  "build": {
    "appId": "com.openclaw.app",
    "productName": "OpenClaw",
    "mac": {
      "target": "dmg",
      "artifactName": "${productName}-Desktop-${version}-${arch}.${ext}"
    },
    "win": {
      "target": "portable",
      "artifactName": "${productName}-Desktop-${version}.${ext}"
    },
    "files": [
      "main.js",
      "package.json"
    ],
    "generateUpdatesFilesForAllChannels": false,
    "publish": null

  },
  "devDependencies": {
    "electron": "^35.7.0",
    "electron-builder": "^26.0.0"
  }
}
